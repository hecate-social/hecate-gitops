# Hecate Daemon Configuration
# This file is the systemd equivalent of the k8s ConfigMap.
# Node-specific overrides go in ~/.hecate/config/node.env

# Mesh Configuration
HECATE_REALM=io.macula
HECATE_BOOTSTRAP=https://boot.macula.io:443
MACULA_MODE=client

# API Configuration (Unix socket only, no TCP)
# The install script replaces this with the actual $HOME-based path.
HECATE_SOCKET_PATH=REPLACE_ME

# LLM Backend
OLLAMA_HOST=http://localhost:11434

# Web Search (SearXNG for agent research)
SEARXNG_URL=http://localhost:8888

# Hardware (overridden per-node via ~/.hecate/config/node.env)
HECATE_RAM_GB=8
HECATE_CPU_CORES=4
HECATE_GPU=none
HECATE_GPU_VRAM_GB=0

# BEAM Clustering
# Cookie must match across all nodes in the cluster
# HECATE_COOKIE=changeme
# HECATE_NODE_NAME=hecate@hostname

# Mesh auto-activation
# Headless deployments (beam cluster, nanodes) have no operator to POST
# /api/mesh/activate, so the daemon dials its relays automatically 5s
# after boot. Leave unset for interactive workstations where the user
# triggers activation through the UI.
HECATE_MESH_AUTOSTART=1

# Admin API bearer token — gates /api/admin/* endpoints (guard inspect,
# catchup stamp, future ops hooks). Leave commented to keep the admin
# surface OFF (daemon returns 503 for /api/admin/* until this is set).
# Generate with: openssl rand -hex 32
# HECATE_ADMIN_TOKEN=CHANGEME
